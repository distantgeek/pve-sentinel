# pve-sentinel configuration
# Copy to config.yaml and customize

# ── Model ──────────────────────────────────────────────────
model:
  # Provider: opencode-go (paid) | opencode-zen (free tier)
  provider: opencode-go
  
  # Model ID — default per provider:
  #   opencode-go: glm-5.1 (recommended for advisory tasks)
  #   opencode-zen: glm-4 (free tier)
  model_id: glm-5.1
  
  # For non-OpenCode providers, uncomment:
  # api_base: https://api.openai.com/v1
  # api_key_env: OPENAI_API_KEY

# ── Security Guardrails ────────────────────────────────────
guardrails:
  # When enabled, every LLM response is constrained to a security framework
  enabled: true
  
  # Select a named preset (mutually exclusive with custom):
  preset: general           # cis-ubuntu-l1 | cis-ai | nist-cyber-ai | general
  
  # Or write a custom system prompt (overrides preset):
  # custom: |
  #   You are a Proxmox VE security advisor operating under [framework].
  #   For every recommendation, reference [specific controls].

# ── Proxmox ────────────────────────────────────────────────
proxmox:
  host: "192.168.x.x"           # Proxmox host IP
  user: "username@pam"          # API user (realm must match token realm)
  token_name: "your-token"      # API token name
  # Token value from environment variable (never hardcoded)
  token_value_env: PROXMOX_TOKEN_VALUE
  node: ""                      # auto-detected if blank
  verify_ssl: true              # Uses user-level CA trust store
                                # Install: uv run python -m src.setup cert

# ── CVE Scanner ────────────────────────────────────────────
cve:
  # Data sources
  nvd_api_enabled: true
  # NVD API key (optional — raises rate limit from 5 req/6s to 50 req/6s)
  # Set NVD_API_KEY environment variable, then uncomment:
  # nvd_api_key_env: NVD_API_KEY
  mitre_api_enabled: true
  exploitdb_enabled: true
  pve_security_enabled: true
  # PVE-SA advisory feed URL
  pve_sa_feed_url: "https://pve.proxmox.com/wiki/Security_Advisories"
  
  # Schedule (systemd timers override these)
  scan_schedule: "daily"       # daily | weekly
  scan_hour: 6
  digest_schedule: "weekly"    # weekly | never
  digest_day: "monday"
  
  # NVD API rate limiting (requests per 6 seconds)
  nvd_rate_limit: 5

# ── Guest Scanning ─────────────────────────────────────────
guests:
  # VM scanning requires QEMU Guest Agent
  vm_scanning: false           # opt-in
  vm_scan_timeout: 30          # seconds per VM
  vm_scan_parallel: 3          # max concurrent VM scans
  
  # LXC scanning uses pct exec (always available)
  lxc_scanning: true           # on by default
  
  # Guest types to skip (comma-separated VMIDs/LXC IDs)
  exclude: []

# ── Permission Gates ───────────────────────────────────────
permissions:
  # Read operations: auto-approved (always)
  # Write operations: require "confirm"
  # Destructive operations: require "CONFIRM-<random>"
  
  # Proxmox API token permissions (must match Proxmox ACL)
  allowed_write_actions:
    - "start"
    - "stop"
    - "reset"
    - "shutdown"
    - "reboot"
    - "suspend"
    - "resume"
  
  # Never allow these (even with confirmation)
  deny_always:
    - "destroy"
    - "remove"
    - "unlink"

# ── Storage ─────────────────────────────────────────────────
storage:
  db_path: "sentinel.db"        # SQLite database path
  digest_dir: "./digests"       # CVE digest output directory
  log_dir: "./logs"             # Application logs
  max_digest_age: 90            # days to keep digests

  # Database maintenance
  auto_vacuum: false            # Run VACUUM automatically on /digest if DB > 50MB
                                # Pros: Keeps DB compact without manual intervention
                                # Cons: Adds ~1-3s to /digest, locks DB during vacuum
                                # Recommendation: Enable for homelab, disable for large deployments
  db_size_threshold_mb: 100     # Warning threshold for DB size alerts
                                # Info at 50MB, warning at 75MB, nag at 100MB+

  # Scan result caching (avoids redundant API calls + LLM token costs)
  scan_cache_ttl_hours: 24      # Hours before /digest runs a fresh scan
                                # Cached results include CVE data + LLM summary
                                # Use /digest force to bypass cache

  # Conversation history (continuity for multi-turn LLM chat)
  conversation_history_depth: 10  # Recent messages injected into each LLM prompt
                                  # Higher = better continuity, more tokens
                                  # Lower = cost savings, lighter local model load
                                  # Set to 0 to disable conversation history
